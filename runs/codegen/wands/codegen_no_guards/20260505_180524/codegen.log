            if sw_in_doc:
                topical_bonus += 0.12
        # "glass rack" ordering boost for rack glass queries
        if 'glass' in q_token_set and 'rack' in q_token_set:
            if (' glass rack ' in f" {t_norm} ") or (' glass rack ' in f" {d_norm} "):
                topical_bonus += 0.12
        # LED intent (no penalty if absent)
        if ('led' in q_token_set) or ('leds' in q_token_set):
            led_in_doc = any(tok in title_set or tok in desc_set for tok in {'led','lighted','lights','lighting','illuminated'})
            if led_in_doc:
                topical_bonus += 0.10
        # Waterproof intent
        if ('waterproof' in q_token_set) or ('water' in q_token_set and 'proof' in q_token_set):
            if any(phrase in f" {t_norm} {d_norm} " for phrase in [' waterproof ',' water-resistant ',' water resistant ',' weatherproof ',' weather resistant ',' all-weather ',' all weather '] ):
