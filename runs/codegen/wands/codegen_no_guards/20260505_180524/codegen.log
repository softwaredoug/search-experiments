            elif has_rug and not has_sw:
                starwars_bonus -= 0.06

        # Numeric/dimension matching bonus: prefer items mentioning the same numbers
        numeric_bonus = 0.0
        if numeric_tokens:
            matched = 0
            for num in numeric_tokens:
