        # Small title match bonus scaled by overlap
        title_bonus = 0.05 * min(w_overlap, 5)
        coverage_bonus = 0.10 * coverage

        # Contextual keyword: "outdoor"
        outdoor_bonus = 0.0
        if 'outdoor' in q_token_set:
