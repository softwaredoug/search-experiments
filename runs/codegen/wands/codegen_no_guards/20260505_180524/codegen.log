            else:
                targeted_bonus -= 0.08
        # Hanging shelf/bookcase intent: favor wall-mounted/floating shelves
        if q_hanging_shelf_intent:
            has_wallish = any(w in title_set or w in desc_set for w in {'wall','mounted','mount','floating','hang','hanging'})
            has_shelf = any(w in title_set or w in desc_set for w in {'shelf','shelves'})
            has_bookcase = ('bookcase' in title_set) or ('bookcase' in desc_set)
            if has_wallish:
                targeted_bonus += 0.18
            if has_shelf:
                targeted_bonus += 0.10
            # be gentle penalizing bookcases to avoid demoting acceptable results
            if has_bookcase and not has_wallish:
