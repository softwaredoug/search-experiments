        # Phrase n-gram matching bonus to strongly reward exact multi-word intent
        phrase_match_count = 0
        if q_ngrams:
            pad_t = f" {t_norm} "
            pad_d = f" {d_norm} "
            for ng in q_ngrams:
                needle = f" {ng} "
                if (needle in pad_t) or (needle in pad_d):
