        'ann': ['anne'],  # queen ann -> queen anne
        # Style & category robustness
        'boho': ['bohemian','boho-chic','bohochic'],
        # Lighting / LED intent
        'led': ['lighted','lights','lighting','illuminated'],
        'leds': ['led','lighted','lights','lighting','illuminated'],
        # Waterproof / weather resistant
        'waterproof': ['water-resistant','water resistant','weatherproof','weather resistant','all-weather','all weather'],
        # Bedding / pillows
        'duvet': ['comforter','cover'],
        'pillow': ['throw','accent','decorative','pillowcase','pillow cover'],
    }

    q_tokens_aug = list(q_tokens)
    q_token_set = set(q_tokens)
    for t in list(q_tokens):
        for alt in token_expansions.get(t, []):
            if alt not in q_token_set:
                q_tokens_aug.append(alt)
