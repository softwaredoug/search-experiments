            # discourage garment/closet racks when shelf intent is explicit
            if not has_shelf and (('garment' in title_set) or ('garment' in desc_set) or ('closet' in title_set) or ('closet' in desc_set)):
                targeted_bonus -= 0.08
        # Hook intent: prefer hooks and penalize faucets without hooks
        if q_hook_intent:
            has_hookish = any(w in title_set or w in desc_set for w in {'hook','hooks','robe','towel','coat'}) and (('hook' in title_set) or ('hooks' in title_set) or ('hook' in desc_set) or ('hooks' in desc_set))
            mentions_faucet = ('faucet' in title_set) or ('faucet' in desc_set)
            if has_hookish:
                targeted_bonus += 0.22
                if 'moen' in q_token_set and (('moen' in title_set) or ('moen' in desc_set)):
                    targeted_bonus += 0.08
            else:
                targeted_bonus -= 0.16
            if mentions_faucet and not has_hookish:
                targeted_bonus -= 0.15
        # Closet door intent: ensure both closet and door words present
        if q_closet_door_intent:
            has_closet = ('closet' in title_set) or ('closet' in desc_set)
            has_door = ('door' in title_set) or ('doors' in title_set) or ('door' in desc_set) or ('doors' in desc_set)
            if has_closet and has_door:
                targeted_bonus += 0.12
            else:
                targeted_bonus -= 0.08
        # Fluffy stool intent: reward furry/shag textures on stools with gentle penalties otherwise
        if q_fluffy_stool_intent:
            has_stool = ('stool' in title_set) or ('stool' in desc_set) or ('stools' in title_set) or ('stools' in desc_set)
            has_fluff = any(w in title_set or w in desc_set for w in fluff_terms.union({'faux fur'}))
            if has_stool and has_fluff:
                targeted_bonus += 0.18
            elif has_stool and not has_fluff:
                targeted_bonus -= 0.06
            else:
                targeted_bonus -= 0.12
        # Ladies/women petite recliner intent: small/petite swivel/rocker recliners
        if q_ladies_recliner_intent:
            has_reclinerish = any(w in title_set or w in desc_set for w in {'recliner','recliners','rocker','rocking'})
            has_swivel = ('swivel' in title_set) or ('swivel' in desc_set)
            mentions_smallish = any(w in title_set or w in desc_set for w in {'small','petite','compact'})
            mentions_women = any(w in title_set or w in desc_set for w in {'women','woman','womens','ladies'})
            if has_reclinerish:
                targeted_bonus += 0.10
            if has_swivel:
                targeted_bonus += 0.08
            if mentions_smallish:
                targeted_bonus += 0.10
            if mentions_women:
                targeted_bonus += 0.06
        # Teen rug intent: ensure rug-like product and youth targeting
        if q_teen_rug_intent:
            has_rug = any(w in title_set or w in desc_set for w in {'rug','rugs'})
            has_youth = any(w in title_set or w in desc_set for w in {'teen','teens','kid','kids','youth','girl','girls','boy','boys'})
            if has_rug and has_youth:
                targeted_bonus += 0.16
            if not has_rug:
                targeted_bonus -= 0.10

        # Weighted combination of retrieval signals
        # Emphasize phrase and AND slightly more; tone down embedding a bit
        score = (
            0.34 * s_or +
            0.32 * s_phrase +
            0.24 * s_and +
            0.15 * s_emb +
            0.07 * s_or_alt +
            0.05 * s_and_alt +
            0.06 * s_phrase_alt +
            title_bonus +
            coverage_bonus +
            must_bonus + must_title_bonus + must_penalty +
            outdoor_bonus +
            color_bonus +
            brand_bonus +
            finish_bonus +
            phrase_bonus +
            prox_bonus +
            style_bonus +
            youth_bonus +
            starwars_bonus +
            numeric_bonus +
            targeted_bonus
        )

        scored.append((score, v['id']))

    # Sort by score desc and return top 10 IDs
    scored.sort(key=lambda x: x[0], reverse=True)
    return [sid for _, sid in scored[:10]]


