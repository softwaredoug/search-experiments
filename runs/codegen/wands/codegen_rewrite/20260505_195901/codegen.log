    op='and' if len(q.split())<=3 else 'or'
    bm=fielded_bm25(q, fields=['title^9.3','description^4.1'], operator=op, top_k=25)
    em=search_embeddings(q, top_k=25)
    mb=max([d['score'] for d in bm] or [1.0]); me=max([d['score'] for d in em] or [1.0])
    S={}; [S.__setitem__(str(d['id']), S.get(str(d['id']),0)+0.7*d['score']/mb) for d in bm]
    [S.__setitem__(str(d['id']), S.get(str(d['id']),0)+0.3*d['score']/me) for d in em]
    return [k for k,_ in sorted(S.items(), key=lambda x: x[1], reverse=True)][:10]

