2026-05-05 16:00:16,432 - code - INFO - def rerank_wands(query, fielded_bm25, search_embeddings, query_rewrite, **kwargs):
    q=(query or '').strip(); alts=query_rewrite(q, max_alternatives=3).get('rewriters',[]) if q else []
